:root {
  --background-image: url("https://raw.githubusercontent.com/TheC0wb0y/Themes2/refs/heads/main/IMG_0753.jpeg");
  --background-size: cover;
  --background-position: center;
  --background-attachment: fixed;
  --background-blur: 0.85;
  --background-alpha: 0.18;
  --main-color: #007bff;
  --hover-color: #0094ba;
  --success-color: #09bd63;
  --danger-color: #ff611a;
}

.theme-dark {
  --background-primary: #000000;
  --background-secondary: #050505;
  --background-tertiary: #111111;
  --background-accent: #1d1d1d;
  --channeltextarea-background: #1a1a1a;
  --input-background: #1a1a1a;
  --text-normal: #ffffff;
  --text-muted: #bdbdbd;
}

body::after {
  content: "Copyright by TheCowboy";
  position: fixed;
  top: 10px;
  right: 12px;
  z-index: 999999;
  color: rgba(255, 255, 255, 0.35);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.5px;
  pointer-events: none;
  text-shadow: 0 0 8px rgba(0, 0, 0, 0.9);
}
